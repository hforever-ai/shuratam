# ============================================
# Shrutam.ai — URL rewrites, compression, caching
# ============================================

RewriteEngine On

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# SEO pages — pre-generated static HTML, Cloudflare caches these automatically
# Files live at: learn-english/{lang}/{slug}/index.html
# Cloudflare: no Page Rules needed — static HTML cached by default (edge TTL: CF default)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^learn-english/([a-z]+)/([a-z0-9-]+)/?$ learn-english/$1/$2/index.html [L]
RewriteRule ^learn-english/([a-z]+)/?$ learn-english/$1/index.html [L]

# Dynamic player — topic-based pretty URLs → player.php
# Format: /learn-english/{lang-word}/{player-slug}/play/
# e.g.   /learn-english/hindi/day-1-greetings-self-introduction/play/
# Real R2 audio URLs never in page source; HMAC tokens minted per request.
# Must come BEFORE the static learn-english rules below.
RewriteRule ^learn-english/(hindi|marathi|telugu)/([a-z0-9-]+)/play/?$ player.php?lang_word=$1&slug=$2 [L,QSA]

# Fallback: numeric URL → player.php (internal / legacy)
RewriteRule ^learn-english/play/([a-z]{2})/(\d+)/?$ player.php?lang=$1&day=$2 [L,QSA]

# English course — serve directory index explicitly
RewriteRule ^spoken-english/?$ spoken-english/index.php [L,QSA]
RewriteRule ^spoken-english/day/(\d+)/?$ spoken-english/index.php?day=$1 [L,QSA]
RewriteRule ^spoken-english/login/?$ spoken-english/login.php [L,QSA]
RewriteRule ^spoken-english/hindi-english/?$ spoken-english/hindi-english/index.php [L,QSA]
RewriteRule ^spoken-english/marathi-english/?$ spoken-english/marathi-english/index.php [L,QSA]

# Multi-language router — route /{lang}/... to router.php
RewriteCond %{REQUEST_URI} ^/(hi|en|mr|te)(/.*)?$
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^(hi|en|mr|te)(/(.*))?$ router.php?lang=$1&path=$3 [L,QSA]

# Remove trailing slash for files, add for directories
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)/$ /$1 [L,R=301]

# Clean URLs: /blind-mode/ → /blind-mode/index.php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.*)$ $1.php [L]

# If request is a directory, serve index.php inside it
DirectoryIndex index.php index.html

# Block access to config directory
<IfModule mod_rewrite.c>
  RewriteRule ^config/ - [F,L]
  RewriteRule ^partials/ - [F,L]
</IfModule>

# ---- Compression ----
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css
  AddOutputFilterByType DEFLATE text/javascript application/javascript
  AddOutputFilterByType DEFLATE application/json application/xml
</IfModule>

# ---- Caching ----
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

# ---- Security headers ----
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set X-XSS-Protection "1; mode=block"
</IfModule>

# ---- Custom error pages ----
ErrorDocument 404 /index.php
